# Copy to .env and fill in. Never commit .env.

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form submissions are delivered. Defaults to team@northstriderconsulting.com.
CONTACT_TO_EMAIL=team@northstriderconsulting.com

# The "from" address that submissions appear from. Until a domain is verified in Resend,
# you can leave this on Resend's sandbox sender. Once the domain is verified, switch to
# something like: "Northstrider <hello@northstriderconsulting.com>"
CONTACT_FROM_EMAIL=Northstrider Contact <onboarding@resend.dev>
