---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTABand from "../../components/CTABand.astro";
import StarMark from "../../components/StarMark.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const studies = await getCollection("caseStudies");
  return studies.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} — Northstrider Consulting`}
  description={entry.data.summary}
>
  <article>
    <header class="relative overflow-hidden border-b border-[color:var(--color-rule)]">
      <div class="bg-constellation absolute inset-0 opacity-40 pointer-events-none"></div>
      <div class="relative mx-auto w-full max-w-4xl px-5 sm:px-8 py-20 sm:py-24">
        <a href="/case-studies" class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-ink)]">
          ← Back to case studies
        </a>
        <p class="mt-6 text-xs uppercase tracking-[0.18em] text-[color:var(--color-gold)]">{entry.data.industry}</p>
        <h1 class="mt-4 font-[Fraunces,serif] text-4xl sm:text-5xl leading-[1.05] tracking-tight">
          {entry.data.title}
        </h1>
        {entry.data.summary && (
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[color:var(--color-ink-muted)]">
            {entry.data.summary}
          </p>
        )}

        <dl class="mt-10 grid gap-8 sm:grid-cols-3 max-w-2xl">
          {entry.data.client && (
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Client</dt>
              <dd class="mt-1 text-[color:var(--color-ink)]">{entry.data.client}</dd>
            </div>
          )}
          {entry.data.services?.length > 0 && (
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">Services</dt>
              <dd class="mt-1 text-[color:var(--color-ink)]">{entry.data.services.join(", ")}</dd>
            </div>
          )}
          {entry.data.metric && (
            <div>
              <dt class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)]">{entry.data.metric.label}</dt>
              <dd class="mt-1 font-[Fraunces,serif] text-2xl text-[color:var(--color-gold)]">{entry.data.metric.value}</dd>
            </div>
          )}
        </dl>
      </div>
    </header>

    <div class="mx-auto w-full max-w-3xl px-5 sm:px-8 py-16 sm:py-24 prose-cs">
      <Content />
    </div>
  </article>

  <CTABand
    heading="Want a similar engagement?"
    body="Tell us where you are today. We'll come back with a candid read."
  />
</BaseLayout>

<style>
  .prose-cs :global(h1) {
    font-family: var(--font-display);
    font-size: 1.875rem;
    line-height: 1.15;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-cs :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-cs :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-cs :global(p) {
    color: var(--color-ink-2);
    line-height: 1.7;
    margin-block: 1rem;
  }
  .prose-cs :global(ul),
  .prose-cs :global(ol) {
    padding-left: 1.25rem;
    margin-block: 1rem;
  }
  .prose-cs :global(ul) {
    list-style: none;
    padding-left: 0;
  }
  .prose-cs :global(ul li) {
    position: relative;
    padding-left: 1.4rem;
    margin-block: 0.5rem;
    color: var(--color-ink-2);
  }
  .prose-cs :global(ul li)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.85em;
    width: 0.8rem;
    height: 1px;
    background: var(--color-gold);
  }
  .prose-cs :global(ol li) {
    margin-block: 0.5rem;
    color: var(--color-ink-2);
  }
  .prose-cs :global(blockquote) {
    border-left: 2px solid var(--color-gold);
    padding-left: 1.25rem;
    margin-block: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-ink-muted);
  }
  .prose-cs :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .prose-cs :global(a) {
    color: var(--color-ink);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 100% 1px;
  }
</style>
