---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CTABand from "../../components/CTABand.astro";

const studies = (await getCollection("caseStudies"))
  .filter((s) => !s.data.draft)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Case Studies — Northstrider Consulting"
  description="Selected Salesforce engagements: implementations, optimizations, and admin-as-a-service. Outcomes, not just deliverables."
>
  <PageHeader
    eyebrow="Case studies"
    title="Selected work."
    lede="A short library of engagements, with the numbers that mattered. More are being prepared as client approvals come in."
  />

  <section class="section">
    <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
      {
        studies.length === 0 ? (
          <div class="rounded border border-dashed border-[color:var(--color-rule)] bg-[color:var(--color-cream-2)] p-10 text-center text-sm text-[color:var(--color-ink-muted)]">
            Case studies coming soon — approvals in progress.
          </div>
        ) : (
          <ul class="grid gap-px overflow-hidden rounded border border-[color:var(--color-rule)] bg-[color:var(--color-rule)] sm:grid-cols-2">
            {studies.map((s) => (
              <li class="bg-[color:var(--color-cream)]">
                <a href={`/case-studies/${s.id}`} class="group block p-8 transition-colors hover:bg-[color:var(--color-cream-2)]">
                  <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-gold)]">{s.data.industry}</p>
                  <h2 class="mt-3 text-2xl leading-snug">{s.data.title}</h2>
                  <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-ink-muted)]">{s.data.summary}</p>
                  <div class="mt-6 flex items-end justify-between gap-4">
                    {s.data.metric ? (
                      <div>
                        <div class="font-[Fraunces,serif] text-3xl text-[color:var(--color-ink)]">{s.data.metric.value}</div>
                        <div class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)] mt-1">{s.data.metric.label}</div>
                      </div>
                    ) : <span />}
                    <span class="text-xs font-medium uppercase tracking-[0.18em] text-[color:var(--color-gold)]">
                      Read →
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <CTABand />
</BaseLayout>
