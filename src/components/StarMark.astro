---
interface Props {
  size?: number;
  class?: string;
  variant?: "gold" | "ink" | "outline";
  title?: string;
}
const { size = 28, class: className = "", variant = "gold", title } = Astro.props;
const fill =
  variant === "gold"
    ? "var(--color-gold)"
    : variant === "ink"
      ? "var(--color-ink)"
      : "transparent";
const stroke = variant === "outline" ? "var(--color-gold)" : "none";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 100 100"
  class={className}
  role={title ? "img" : "presentation"}
  aria-hidden={title ? undefined : "true"}
  aria-label={title}
>
  <path
    d="M50 2 L56 44 L98 50 L56 56 L50 98 L44 56 L2 50 L44 44 Z"
    fill={fill}
    stroke={stroke}
    stroke-width="2"
  />
</svg>
