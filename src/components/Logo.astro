---
import Mountains from "./Mountains.astro";
interface Props {
  href?: string;
  size?: "sm" | "md";
}
const { href = "/", size = "md" } = Astro.props;
const markClass = size === "sm" ? "h-[26px] w-auto shrink-0" : "h-9 w-auto shrink-0";
const wordClass =
  size === "sm"
    ? "text-[1.15rem]"
    : "text-[1.25rem] sm:text-[1.35rem]";
---

<a href={href} class="inline-flex items-center gap-3 group" aria-label="Northstrider Consulting — home">
  <Mountains decorative class={markClass} />
  <span
    class={`font-[Fraunces,serif] ${wordClass} tracking-tight text-[color:var(--color-ink)] leading-none`}
    style="font-variation-settings: 'opsz' 24, 'SOFT' 30;"
  >
    <span class="font-medium">North</span><span class="font-normal italic">strider</span>
  </span>
</a>
