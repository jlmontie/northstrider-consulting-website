---
import { getCollection } from "astro:content";

const studies = (await getCollection("caseStudies"))
  .filter((s) => !s.data.draft)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);
---

<section class="section bg-[color:var(--color-cream-2)]">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div>
        <span class="eyebrow">Selected work</span>
        <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl">Outcomes, not deliverables.</h2>
        <span class="rule-divider mt-6"></span>
      </div>
      <a href="/case-studies" class="link-underline text-sm font-medium text-[color:var(--color-ink-2)]">
        View all case studies →
      </a>
    </div>

    {
      studies.length === 0 ? (
        <div class="mt-12 rounded border border-dashed border-[color:var(--color-rule)] bg-[color:var(--color-cream)] p-10 text-center text-sm text-[color:var(--color-ink-muted)]">
          {/* TODO: Replace once first 1-3 case studies are approved by clients. */}
          Case studies coming soon — approvals in progress with three pilot clients.
        </div>
      ) : (
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {studies.map((s) => (
            <a
              href={`/case-studies/${s.id}`}
              class="card group block"
            >
              <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-gold)]">{s.data.industry}</p>
              <h3 class="mt-3 text-xl leading-snug">{s.data.title}</h3>
              <p class="mt-3 text-sm text-[color:var(--color-ink-muted)] line-clamp-3">{s.data.summary}</p>
              {s.data.metric && (
                <p class="mt-5 font-[Fraunces,serif] text-3xl text-[color:var(--color-ink)]">
                  {s.data.metric.value}
                  <span class="block text-xs font-normal uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)] mt-1">
                    {s.data.metric.label}
                  </span>
                </p>
              )}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
