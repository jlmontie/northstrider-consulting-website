---
// Salesforce certifications shown as a tidy grid. Holders are added per-cert when client provides certs/owners.
const certs = [
  { name: "Salesforce Administrator", abbr: "ADM" },
  { name: "Advanced Administrator", abbr: "ADV" },
  { name: "Platform App Builder", abbr: "PAB" },
  { name: "Sales Cloud Consultant", abbr: "SCC" },
  { name: "Service Cloud Consultant", abbr: "SVC" },
  { name: "Experience Cloud Consultant", abbr: "EXP" },
];
---

<section class="section">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="text-center">
      <span class="eyebrow">Certified expertise</span>
      <h2 class="mt-4 text-3xl sm:text-4xl">Salesforce certifications held by the team</h2>
      <span class="rule-divider rule-divider-center mt-6"></span>
    </div>

    <ul class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      {
        certs.map((c) => (
          <li class="flex flex-col items-center gap-3 rounded border border-[color:var(--color-rule)] bg-[color:var(--color-cream)] p-5 text-center transition-colors hover:border-[color:var(--color-gold)]">
            <div class="grid h-14 w-14 place-items-center rounded-full border border-[color:var(--color-gold)]/40 bg-[color:var(--color-gold-soft)]/40 font-[Fraunces,serif] text-sm tracking-wider text-[color:var(--color-gold)]">
              {c.abbr}
            </div>
            <p class="text-xs leading-snug text-[color:var(--color-ink-2)]">{c.name}</p>
          </li>
        ))
      }
    </ul>
    <p class="mt-6 text-center text-xs text-[color:var(--color-ink-muted)]">
      <!-- TODO: Replace placeholder badges with official Salesforce credential SVGs and link each to Trailblazer profile. -->
      Replace placeholders with official Salesforce credential badges once team certifications are confirmed.
    </p>
  </div>
</section>
